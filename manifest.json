{
  "manifest_version": 3,
  "name": "Focus Timer",
  "version": "1.0.0",
  "description": "A basic pomodoro timer extension.",
  "icons": {
    "16": "icon-96.png",
    "48": "icon-96.png",
    "128": "icon-96.png"
  },
  "action": {
    "defualt_icon": {
        "16": "icon-96.png",
        "24": "icon-96.png",
        "32": "icon-96.png"
    },
    "default_title": "Focus Timer",
    "default_popup": "popup.html"
  },
  "background": "background.js",
  "permissions": [
    "storage"
  ]
}